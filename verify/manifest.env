# e2e-verify manifest — end-to-end functional-acceptance loop.
# Sourced by the host verify runner AND the ci.yml `e2e` job. Commands may use
# $PORT and any exported vars. See verify/acceptance/ for the black-box suite.

MODE=compose
PORT=8010
BOARD=strava

# Isolated bring-up. The app container runs `alembic upgrade head` on startup
# (see Dockerfile CMD), so UP only needs to build + start.
UP="APP_PORT=$PORT docker compose -p strava-e2e up --build -d"

# Clean teardown — containers, networks, volumes.
DOWN="docker compose -p strava-e2e down -v --remove-orphans"

# Readiness probe (runs on the host/runner, which has curl). Retried by the runner.
READY="curl -sf http://localhost:${PORT:-8010}/healthz"

# Logs captured on failure.
LOGS="docker compose -p strava-e2e logs --tail=50"

# Black-box client deps only — never the app's own deps.
TEST_DEPS="pytest pytest-asyncio httpx"

# Acceptance command. Runs from verify/; .venv is provisioned from TEST_DEPS.
ACCEPTANCE="cd verify && API_BASE_URL=http://localhost:${PORT:-8010} .venv/bin/pytest acceptance/ -v"
